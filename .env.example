# API mode selection (gen-ai SDK standard)
# Reference: https://googleapis.github.io/js-genai/release_docs/index.html
# Default behavior:
# - Uses Vertex AI when GOOGLE_CLOUD_PROJECT is set
# - Uses Google AI Studio / Gemini Developer API when only GEMINI_API_KEY or GOOGLE_API_KEY is set
# - Set GOOGLE_GENAI_USE_VERTEXAI=true|false to force a mode
# GOOGLE_GENAI_USE_VERTEXAI=true

# Vertex AI configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Google AI Studio / Gemini Developer API configuration
# GEMINI_API_KEY=your-ai-studio-api-key
# GOOGLE_API_KEY=your-ai-studio-api-key

# Vertex AI authentication: Google Cloud credentials
# Method 1: Application Default Credentials (recommended for local development)
# Run: gcloud auth application-default login

# Method 2: Service Account Key File (recommended for production)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Model Configuration
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TEMPERATURE=1.0
GEMINI_MAX_TOKENS=8192
GEMINI_TOP_P=0.95
GEMINI_TOP_K=40
# Optional for multimodal inputs: low, medium, high
# GEMINI_MEDIA_RESOLUTION=medium

# Generated file output directories
# Defaults:
# - Images: ~/Pictures/gemini-generated
# - Videos: ~/Movies/gemini-generated on macOS, ~/Videos/gemini-generated on Windows/Linux
#           (generate_video and generate_omni_video both save here)
# - Speech: ~/Music/gemini-generated/speech
# - Music: ~/Music/gemini-generated/music
# GEMINI_IMAGE_OUTPUT_DIR=/path/to/images
# GEMINI_VIDEO_OUTPUT_DIR=/path/to/videos
# GEMINI_SPEECH_OUTPUT_DIR=/path/to/speech
# GEMINI_MUSIC_OUTPUT_DIR=/path/to/music

# Agent Mode: Conversation Management
GEMINI_ENABLE_CONVERSATIONS=false  # Set to 'true' to enable multi-turn conversations
GEMINI_SESSION_TIMEOUT=3600        # Session timeout in seconds (default: 1 hour)
GEMINI_MAX_HISTORY=10              # Maximum messages to keep in conversation history

# Agent Mode: Chain of Thought Reasoning
GEMINI_ENABLE_REASONING=false      # Set to 'true' to enable reasoning capability
GEMINI_MAX_REASONING_STEPS=5       # Maximum reasoning steps (default: 5)

# System Prompt Customization
# Override the default system prompt to customize AI assistant behavior
# Example: GEMINI_SYSTEM_PROMPT="You are a financial analyst. You have access to the following tools:"
# GEMINI_SYSTEM_PROMPT=

# Logging Configuration
# Default: Console logging (stderr)
# Set GEMINI_LOG_TO_STDERR=false to use file logging instead
GEMINI_DISABLE_LOGGING=false       # Set to 'true' to disable logging completely
GEMINI_LOG_TO_STDERR=true          # Default: true (console logging to stderr)
# GEMINI_LOG_DIR=/path/to/logs     # Custom directory for log files (only used when LOG_TO_STDERR=false)

# Agent Mode: MCP-to-MCP Connectivity
# GEMINI_MCP_SERVERS='[{"name":"server1","command":"node","args":["path/to/server.js"],"env":{}}]'
